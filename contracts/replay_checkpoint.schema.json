{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/genesis-core/contracts/replay_checkpoint.schema.json",
  "title": "Replay Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["checkpoint_id", "instance_id", "seed_hash", "from_event_id", "to_event_id", "event_count", "checkpoint_hash", "replay_result_ref", "created_at"],
  "properties": {
    "checkpoint_id": { "type": "string", "minLength": 1 },
    "instance_id": { "type": "string", "minLength": 1 },
    "seed_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "from_event_id": { "type": ["string", "null"] },
    "to_event_id": { "type": ["string", "null"] },
    "event_count": { "type": "integer", "minimum": 0 },
    "checkpoint_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "replay_result_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" }
  }
}
