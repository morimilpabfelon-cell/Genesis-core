{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/genesis-core/contracts/living_memory_event.schema.json",
  "title": "Living Memory Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "instance_id", "seed_hash", "previous_event_hash", "event_type", "memory_kind", "actor", "source", "body", "importance", "confidence", "guardian_confirmed", "links", "evidence", "privacy_scope", "created_at", "event_hash"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "instance_id": { "type": "string", "minLength": 1 },
    "seed_hash": { "type": "string", "pattern": "^sha256:.+" },
    "previous_event_hash": { "type": ["string", "null"] },
    "event_type": { "type": "string", "minLength": 1 },
    "memory_kind": { "type": "string", "enum": ["identity_memory", "episodic_memory", "semantic_memory", "project_memory", "preference_memory", "relationship_memory", "skill_memory", "correction_memory", "decision_memory", "warning_memory", "integrity_memory", "migration_memory"] },
    "actor": { "type": "string", "enum": ["guardian", "instance", "system"] },
    "source": { "type": "string", "enum": ["local", "guardian", "system", "external_context", "reasoning_turn", "rest_cycle"] },
    "body": { "type": "string", "minLength": 1 },
    "importance": { "type": "integer", "minimum": 1, "maximum": 100 },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "guardian_confirmed": { "type": "boolean" },
    "links": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "items": { "type": "object" } },
    "privacy_scope": { "type": "string", "enum": ["local_private", "guardian_visible", "export_approved"] },
    "created_at": { "type": "string" },
    "event_hash": { "type": "string", "pattern": "^sha256:.+" }
  }
}
