{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/genesis-core/contracts/recall_schedule.schema.json",
  "title": "Recall Schedule",
  "type": "object",
  "additionalProperties": false,
  "required": ["recall_id", "instance_id", "target_event_id", "reason", "priority", "interval", "due_at", "last_reviewed_at", "status", "created_at"],
  "properties": {
    "recall_id": { "type": "string", "minLength": 1 },
    "instance_id": { "type": "string", "minLength": 1 },
    "target_event_id": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "priority": { "type": "integer", "minimum": 1, "maximum": 100 },
    "interval": { "type": "string", "minLength": 1 },
    "due_at": { "type": "string" },
    "last_reviewed_at": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["active", "reviewed", "reinforced", "degraded", "archived"] },
    "created_at": { "type": "string" }
  }
}
