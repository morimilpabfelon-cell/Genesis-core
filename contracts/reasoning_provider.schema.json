{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/genesis-core/contracts/reasoning_provider.schema.json",
  "title": "Reasoning Provider",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider_id",
    "provider_type",
    "scope",
    "locality",
    "requires_guardian_approval",
    "stores_identity",
    "stores_memory",
    "allowed_for_turn"
  ],
  "properties": {
    "provider_id": { "type": "string", "minLength": 1 },
    "provider_type": { "type": "string", "enum": ["own_local_engine", "local_auxiliary", "external_auxiliary"] },
    "scope": { "type": "string", "enum": ["internal_default", "approved_turn", "approved_session", "disabled"] },
    "locality": { "type": "string", "enum": ["device_local", "trusted_local", "external_remote"] },
    "requires_guardian_approval": { "type": "boolean" },
    "stores_identity": { "type": "boolean", "const": false },
    "stores_memory": { "type": "boolean", "const": false },
    "allowed_for_turn": { "type": "boolean" }
  },
  "allOf": [
    {
      "if": { "properties": { "provider_type": { "const": "own_local_engine" } }, "required": ["provider_type"] },
      "then": { "properties": { "requires_guardian_approval": { "const": false } } }
    },
    {
      "if": { "properties": { "provider_type": { "const": "external_auxiliary" } }, "required": ["provider_type"] },
      "then": { "properties": { "requires_guardian_approval": { "const": true } } }
    }
  ]
}
