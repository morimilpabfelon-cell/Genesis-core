{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/genesis-core/contracts/evidence_record.schema.json",
  "title": "Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence_id", "instance_id", "evidence_type", "locator", "digest", "captured_at", "captured_by", "trust_tier", "summary"],
  "properties": {
    "evidence_id": { "type": "string", "minLength": 1 },
    "instance_id": { "type": "string", "minLength": 1 },
    "evidence_type": { "type": "string", "enum": ["guardian_input", "local_event", "validation_output", "approval_record", "artifact_digest", "external_context", "tool_result", "rest_cycle_record"] },
    "locator": { "type": "string" },
    "digest": { "type": "string" },
    "captured_at": { "type": "string" },
    "captured_by": { "type": "string", "enum": ["guardian", "instance", "system"] },
    "trust_tier": { "type": "string", "enum": ["guardian_confirmed", "local_verified", "local_unverified", "external_untrusted", "derived", "quarantine_only"] },
    "summary": { "type": "string" }
  }
}
