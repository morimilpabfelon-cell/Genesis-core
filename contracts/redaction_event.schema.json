{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/genesis-core/contracts/redaction_event.schema.json",
  "title": "Redaction Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["redaction_id", "instance_id", "target_id", "target_type", "redacted_fields", "redaction_marker", "reason", "approval_ref", "evidence_refs", "created_at", "redaction_hash"],
  "properties": {
    "redaction_id": { "type": "string", "minLength": 1 },
    "instance_id": { "type": "string", "minLength": 1 },
    "target_id": { "type": "string", "minLength": 1 },
    "target_type": { "type": "string", "enum": ["memory_event", "knowledge_capsule", "evidence_record", "snapshot"] },
    "redacted_fields": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "redaction_marker": { "type": "string", "const": "[REDACTED_BY_GUARDIAN_POLICY]" },
    "reason": { "type": "string", "minLength": 1 },
    "approval_ref": { "type": "string", "minLength": 1 },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string" },
    "redaction_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
